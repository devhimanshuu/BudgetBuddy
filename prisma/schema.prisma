// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("POSTGRES_PRISMA_URL")
  directUrl = env("POSTGRES_URL_NON_POOLING")
}


model UserSettings{
  userId   String @id
  currency String
  
  // Gamification fields
  currentStreak Int @default(0)
  longestStreak Int @default(0)
  lastActivityDate DateTime?
  totalPoints Int @default(0)

  // ALERT & NOTIFICATION SETTINGS
  spendingLimitThreshold Int     @default(80) // % of budget reached
  enableAnomalyDetection Boolean @default(true)
  anomalyThreshold       Float   @default(2.0) // Multiplier of average (e.g., 2x)
  activeTheme            String  @default("default") // "default", "midnight", "gold"

  // VAULT PIN SETTINGS
  vaultPin               String?  // SHA-256 hashed PIN (null = not set)
  vaultPinEnabled        Boolean @default(false)
}

model Workspace {
  id        String   @id @default(uuid())
  name      String
  ownerId   String
  currency  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members               WorkspaceMember[]
  invites               Invite[]
  categories            Category[]
  transactions          Transaction[]
  tags                  Tag[]
  budgets               Budget[]
  savingsGoals          SavingsGoal[]
  assets                Asset[]
  recurringTransactions RecurringTransaction[]
  monthlyHistory        MonthlyHistory[]
  yearHistory           YearHistory[]
  activities            Activity[]
  vaultEntries          VaultEntry[]
  beneficiaries         Beneficiary[]
}

model WorkspaceMember {
  id          String   @id @default(uuid())
  workspaceId String
  userId      String
  role        String   @default("VIEWER") // VIEWER, EDITOR, ADMIN
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
}

model Invite {
  id          String   @id @default(uuid())
  email       String
  workspaceId String
  role        String   @default("VIEWER")
  token       String   @unique
  expiresAt   DateTime
  createdAt   DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

model Category {
  createdAt   DateTime @default(now())
  name        String
  userId      String
  workspaceId String?
  icon        String
  type        String   @default("income")

  workspace Workspace? @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@id([name, userId, type])
}

model Transaction {
  id          String   @id @default(uuid())
  createdAt   DateTime @default(now())
  updateAt    DateTime @default(now())
  workspaceId String?

  amount      Float
  description String
  notes       String? // Optional notes field
  date        DateTime
  userId      String
  type        String   @default("income")

  category     String
  categoryIcon String

  tags         TransactionTag[]
  attachments  Attachment[]
  splits       TransactionSplit[]
  history      TransactionHistory[]
  workspace    Workspace?           @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, date])
  @@index([workspaceId, category])
  @@index([userId, type, date]) // Optimize "Get all expenses for month"
  @@index([userId, date, type]) // Optimize date range + type filtering
}

model Tag {
  id          String   @id @default(uuid())
  name        String
  color       String   @default("#3b82f6") // Default blue color
  userId      String
  workspaceId String?
  createdAt   DateTime @default(now())

  transactions TransactionTag[]
  workspace    Workspace?        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([name, userId])
  @@index([workspaceId])
}

model TransactionTag {
  transactionId String
  tagId         String

  transaction Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  tag         Tag         @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([transactionId, tagId])
}

model Attachment {
  id            String   @id @default(uuid())
  transactionId String
  fileName      String
  fileUrl       String
  fileSize      Int
  fileType      String
  uploadedAt    DateTime @default(now())

  transaction Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)

  @@index([transactionId])
}

model MonthlyHistory {
  userId      String
  workspaceId String?
  day         Int
  month       Int
  year        Int
  income      Float
  expense     Float

  workspace Workspace? @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@id([day, month, year, userId]) // Keeping userId in ID for now
  @@index([userId, month, year]) // Optimize stats/dashboard queries
}

model YearHistory {
  userId      String
  workspaceId String?
  month       Int
  year        Int
  income      Float
  expense     Float

  workspace Workspace? @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@id([month, year, userId]) // Keeping userId in ID for now
}

model Budget {
  userId       String
  workspaceId  String?
  category     String
  categoryIcon String
  amount       Float
  month        Int
  year         Int
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  workspace Workspace? @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@id([userId, category, month, year])
  @@index([workspaceId, month, year])
}

model SavingsGoal {
  id            String   @id @default(uuid())
  userId        String
  workspaceId   String?
  name          String
  description   String?
  targetAmount  Float
  currentAmount Float    @default(0)
  targetDate    DateTime
  category      String   @default("General")
  icon          String   @default("🎯")
  color         String   @default("#3b82f6")
  isCompleted   Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  workspace Workspace? @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([workspaceId, isCompleted])
}

model TransactionSplit {
  id            String @id @default(uuid())
  transactionId String
  category      String
  categoryIcon  String
  amount        Float
  percentage    Float
  
  transaction Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  

  
  @@index([transactionId])
}

model TransactionHistory {
  id            String   @id @default(uuid())
  transactionId String
  amount        Float
  description   String
  notes         String?
  date          DateTime
  category      String
  categoryIcon  String
  type          String
  tags          String[] // Storing tag IDs as array of strings
  changedAt     DateTime @default(now())

  transaction   Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)

  @@index([transactionId])
}

model Asset {
  id           String   @id @default(uuid())
  userId       String
  workspaceId  String?
  name         String
  description  String?
  type         String // "asset" or "liability"
  category     String // "stocks", "real-estate", "crypto", "cash", "mortgage", "loan", "credit-card", "other"
  currentValue Float
  icon         String   @default("💰")
  color        String   @default("#3b82f6")
  notes        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  
  history   AssetHistory[]
  workspace Workspace?      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([workspaceId, type])
  @@index([workspaceId, category])
}

model AssetHistory {
  id        String   @id @default(uuid())
  assetId   String
  value     Float
  date      DateTime
  notes     String?
  createdAt DateTime @default(now())
  
  asset Asset @relation(fields: [assetId], references: [id], onDelete: Cascade)
  
  @@index([assetId])
  @@index([assetId, date])
}

model RecurringTransaction {
  id          String   @id @default(uuid())
  userId      String
  workspaceId String?
  amount      Float
  description String
  type        String   @default("income") // "income" or "expense"
  
  category     String
  categoryIcon String
  
  date     DateTime // Next due date
  interval String // "daily", "weekly", "monthly", "yearly"
  
  lastProcessed DateTime? 
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workspace Workspace? @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
}

model Achievement {
  id String @id @default(uuid())
  key String @unique // e.g., "first_transaction", "streak_7", "budget_hero"
  name String
  description String
  icon String
  category String // "streak", "budget", "savings", "general"
  tier String @default("bronze") // "bronze", "silver", "gold", "platinum"
  points Int @default(10)
  requirement Int? // e.g., 7 for "7 day streak"
  createdAt DateTime @default(now())
  
  userAchievements UserAchievement[]
}

model UserAchievement {
  id String @id @default(uuid())
  userId String
  achievementId String
  unlockedAt DateTime @default(now())
  progress Int @default(0) // For tracking progress towards achievement
  
  achievement Achievement @relation(fields: [achievementId], references: [id], onDelete: Cascade)
  
  @@unique([userId, achievementId])
  @@index([userId])
  @@index([userId, unlockedAt])
}

model Activity {
  id          String   @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  userId      String
  type        String   // e.g., "TRANSACTION_CREATED", "MEMBER_INVITED", "WORKSPACE_CREATED"
  description String
  metadata    Json?    // Optional extra info like transaction amount or member email
  createdAt   DateTime @default(now())

  @@index([workspaceId])
  @@index([userId])
}

model VaultEntry {
  id            String   @id @default(uuid())
  userId        String
  workspaceId   String?
  title         String
  content       String   // Encrypted content (instructions, secrets, locations)
  category      String   // "insurance", "legal", "crypto", "banking", "property", "medical", "other"
  icon          String   @default("🔒")
  sensitivity   String   @default("high") // "low", "medium", "high", "critical"
  notes         String?
  lastVerified  DateTime? // When user last confirmed info is still valid
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  workspace Workspace? @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([userId])
}

model Beneficiary {
  id            String   @id @default(uuid())
  userId        String
  workspaceId   String?
  name          String
  email         String
  relationship  String   // "spouse", "child", "parent", "sibling", "lawyer", "accountant", "other"
  phone         String?
  notes         String?
  accessLevel   String   @default("full") // "full", "partial", "emergency-only"
  isVerified    Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  workspace Workspace? @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([userId])
}
